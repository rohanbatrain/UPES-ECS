root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# PowerShell stays CRLF (Windows-native tooling)
[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf
indent_size = 4

[*.sh]
end_of_line = lf

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
