# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# UPES-ECS reads runtime configuration from the environment / provisioning files;
# this template documents the operator-supplied values.

# --- Network ---------------------------------------------------------------
UPES_LAN_IP=192.168.1.21          # LAN IP the PBX/console binds to
UPES_HOSTNAME=upes-ecs-pbx-01     # mDNS hostname (upes-ecs.local)

# --- SIP / provisioning ----------------------------------------------------
# Secrets are pinned per-account by deploy/qemu/Add-UpesUser.ps1 — do NOT set
# real SIP passwords here or in any committed file.
SIP_ADMIN_SECRET=changeme

# --- SSH to deployment targets (QEMU VM / Jetson) --------------------------
JETSON_HOST=192.168.1.35
JETSON_SSH_KEY_PATH=./secrets/jetson_key   # key lives under git-ignored secrets/

# --- IVR / language --------------------------------------------------------
UPES_DEFAULT_LANG=en
