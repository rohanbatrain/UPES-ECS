# UPES-ECS CardDAV (Radicale) server config.  Installed to /etc/radicale/config by
# install-carddav.sh. LAN-only, read-only shared campus directory for phones.
[server]
# Listen on all interfaces so campus phones reach it via the QEMU forward / hostname.
hosts = 0.0.0.0:5232
# Plain HTTP on a closed LAN appliance (phones + PBX on the same private network).
# For TLS, terminate in front and see api/carddav/README.md.
max_connections = 40

[auth]
type = htpasswd
htpasswd_filename = /etc/radicale/users
# install-carddav.sh sets this to bcrypt when available, else plain (dependency-free).
htpasswd_encryption = __HTPASSWD_ENC__

[rights]
type = from_file
file = /etc/radicale/rights

[storage]
filesystem_folder = /var/lib/radicale/collections

[logging]
# Quiet by default; journalctl -u upes-carddav shows startup + errors.
level = warning
