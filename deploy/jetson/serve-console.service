[Unit]
Description=UPES-ECS Operations Console (Linux static server + /api proxy on :8080)
After=network.target upes-api.service
Wants=upes-api.service

[Service]
Type=simple
User=root
Environment=UPES_CONSOLE_ROOT=/opt/upes-ecs/console
Environment=UPES_CONSOLE_PORT=8080
Environment=UPES_API_BASE=http://127.0.0.1:8090
ExecStart=/usr/bin/python3 /opt/upes-ecs/ha/serve-console.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
