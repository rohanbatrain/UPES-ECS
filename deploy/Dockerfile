# UPES-ECS — self-contained Asterisk (Ubuntu 22.04 → Asterisk 18 LTS) for the current
# node. Bakes in the helper scripts + custom dialplan and prepares state/recording dirs
# so the FULL emergency flow (incident IDs, missed-incident logging, recording,
# escalation, voicemail) runs end-to-end. LAN-only; live phone audio -> Linux/van.
#
# Build context is the REPO ROOT (see docker-compose.yml) so scripts/ and config/ are
# available to COPY.
FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends asterisk asterisk-core-sounds-en-gsm \
 && rm -rf /var/lib/apt/lists/*

# Helper scripts + the real dialplan. extensions.conf #includes the feature files
# below, so ALL of them must be present or Asterisk silently skips the missing
# includes (which is how ctx_callout / the feature contexts went unloaded before).
COPY scripts/ /opt/upes-ecs/
COPY deploy/asterisk/extensions.conf /etc/asterisk/extensions.conf
COPY config/extensions_custom.conf          /etc/asterisk/extensions_custom.conf
COPY config/extensions_features.conf        /etc/asterisk/extensions_features.conf
COPY config/extensions_features_wiring.conf /etc/asterisk/extensions_features_wiring.conf
COPY config/extensions_aihelpline.conf      /etc/asterisk/extensions_aihelpline.conf
# Professional EAS (Emergency Alert Service) mass-callout prompts — Piper neural TTS,
# 8 kHz mono WAV (generated by scripts/gen-callout-prompts.sh). Ship so callouts have
# real audio out of the box: custom/upes-* announcements + upes-ecs/rollcall-* controls.
COPY deploy/asterisk/sounds/en/ /usr/share/asterisk/sounds/en/
COPY deploy/entrypoint.sh /entrypoint.sh

RUN chmod +x /opt/upes-ecs/*.sh /entrypoint.sh \
 && mkdir -p /var/lib/upes-ecs/incidents /var/lib/upes-ecs/alerts \
             /var/lib/upes-ecs/security /var/lib/upes-ecs/paging \
             /var/lib/upes-ecs/conference /var/lib/upes-ecs/retention \
             /var/spool/asterisk/monitor/upes-ecs \
 && chown -R asterisk:asterisk /var/lib/upes-ecs /var/spool/asterisk/monitor/upes-ecs /opt/upes-ecs \
             /usr/share/asterisk/sounds/en/custom /usr/share/asterisk/sounds/en/upes-ecs

ENTRYPOINT ["/entrypoint.sh"]
